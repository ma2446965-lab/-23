---
import { SITE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';

// Replace with your real support address before launch.
const CONTACT_EMAIL = 'contact@calcutils.example';
---

<BaseLayout
  title="Contact"
  description={`Contact ${SITE.name}. Send feedback, report a bug, or request a new free tool.`}
>
  <div class="container" style="max-width: 760px; padding: 2rem 1.25rem 3rem;">
    <h1>Contact us</h1>
    <section class="prose">
      <p>
        We’re a small team and read every message. Whether you found a bug, have a suggestion, or
        want to request a new free tool, we’d love to hear from you.
      </p>

      <h2>Email</h2>
      <p>
        The fastest way to reach us is by email:
        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
        <br />
        <small>(Replace this address with your own support email before launching.)</small>
      </p>

      <h2>What to include</h2>
      <ul>
        <li>The name of the tool or page you’re writing about.</li>
        <li>A short description of the issue or idea.</li>
        <li>Any example inputs that produced unexpected results.</li>
      </ul>

      <h2>Response time</h2>
      <p>We aim to reply within a few business days, though high-volume periods may take longer.</p>
    </section>

    <AdSlot id="inContent" label="Advertisement" />
  </div>
</BaseLayout>

---
import { SITE } from '../consts';
import { categories, tools, getToolsByCategory } from '../data/tools';
import { websiteJsonLd } from '../lib/seo';
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import RelatedTools from '../components/RelatedTools.astro';

const featured = tools.slice(0, 6);
const jsonLd = [websiteJsonLd()];
---

<BaseLayout title={SITE.name} description={SITE.description} jsonLd={jsonLd}>
  <div class="container home">
    <section class="hero">
      <span class="hero__eyebrow">⚡ {SITE.name} · 34+ Free Tools</span>
      <h1>
        <span class="gradient-text" data-i18n="footer.tagline" data-en={SITE.tagline}>{SITE.tagline}</span>
      </h1>
      <p class="lead">{SITE.description}</p>
      <div class="hero__cta">
        <a href="/calculators/" class="btn btn-primary" data-i18n="btn.browse" data-en="Browse all tools">
          Browse all tools →
        </a>
      </div>
      <div class="hero__stats">
        <div><b>34</b> Free tools</div>
        <div><b>18</b> Languages</div>
        <div><b>100%</b> Client-side</div>
      </div>
    </section>

    <AdSlot id="top" label="Advertisement" />

    {
      categories.map((cat) => (
        <section class="cat-section">
          <div class="cat-head">
            <h2>
              <span class="cat-icon" aria-hidden="true">{cat.icon}</span>{' '}
              <span data-i18n={`cat.${cat.slug}`} data-en={cat.title}>{cat.title}</span>
            </h2>
            <a href={`/${cat.slug}/`} data-i18n="btn.viewAll" data-en="View all">View all →</a>
          </div>
          <RelatedTools tools={getToolsByCategory(cat.slug)} />
        </section>
      ))
    }

    <AdSlot id="inContent" label="Advertisement" />

    <section class="featured">
      <h2 class="section-title" data-i18n="home.popular" data-en="Popular tools">Popular tools</h2>
      <RelatedTools tools={featured} />
    </section>
  </div>
</BaseLayout>

<style>
  .home { padding-top: 1rem; padding-bottom: 2rem; }
  .hero__eyebrow { display: inline-flex; }
  .cat-section { margin-top: 2.5rem; }
  .featured { margin-top: 2.75rem; }
</style>

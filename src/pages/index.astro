---
import { SITE } from '../consts';
import { categories, tools, getToolsByCategory } from '../data/tools';
import { websiteJsonLd } from '../lib/seo';
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import RelatedTools from '../components/RelatedTools.astro';

const featured = tools.slice(0, 6);
const jsonLd = [websiteJsonLd()];
---

<BaseLayout title={SITE.name} description={SITE.description} jsonLd={jsonLd}>
  <div class="container home">
    <section class="hero">
      <h1>{SITE.tagline}</h1>
      <p class="lead">{SITE.description}</p>
      <a href="/calculators/" class="btn btn-primary">Browse all tools →</a>
    </section>

    <AdSlot id="top" label="Advertisement" />

    {
      categories.map((cat) => (
        <section class="cat-section">
          <div class="cat-head">
            <h2>{cat.icon} {cat.title}</h2>
            <a href={`/${cat.slug}/`}>View all →</a>
          </div>
          <RelatedTools tools={getToolsByCategory(cat.slug)} />
        </section>
      ))
    }

    <AdSlot id="inContent" label="Advertisement" />

    <section class="featured">
      <h2>Popular tools</h2>
      <RelatedTools tools={featured} />
    </section>
  </div>
</BaseLayout>

<style>
  .home { padding-top: 1.5rem; padding-bottom: 2rem; }
  .hero {
    text-align: center;
    padding: 2.5rem 1rem 2rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0 0 1rem;
  }
  .hero .lead {
    font-size: 1.15rem;
    color: var(--color-ink-600);
    max-width: 60ch;
    margin: 0 auto 1.5rem;
  }
  .cat-section { margin-top: 2.25rem; }
  .cat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--color-ink-200);
    padding-bottom: 0.5rem;
  }
  .cat-head h2 { font-size: 1.5rem; margin: 0; }
  .featured { margin-top: 2.5rem; }
  .featured h2 { font-size: 1.5rem; }
</style>

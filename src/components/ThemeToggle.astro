---
// Theme toggle. The engine (src/i18n/index.ts) keeps the icon + label in sync.
---
<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-pressed="false"
  data-i18n-attr="aria-label:theme.toggle"
>
  <span class="theme-toggle__icon" aria-hidden="true">🌙</span>
  <span class="theme-toggle__label visually-hidden">Dark</span>
</button>

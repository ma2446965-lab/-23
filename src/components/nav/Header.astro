---
import { SITE, PRIMARY_NAV } from '../../consts';
import LangSwitcher from '../LangSwitcher.astro';
import ThemeToggle from '../ThemeToggle.astro';

const path = Astro.url.pathname;

const NAV_KEYS: Record<string, string> = {
  '/calculators/': 'nav.calculators',
  '/converters/': 'nav.converters',
  '/generators/': 'nav.generators',
  '/about/': 'nav.about',
  '/contact/': 'nav.contact',
};
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <span class="brand__grad brand__logo" aria-hidden="true">C</span>
      <span>{SITE.name}</span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        {
          PRIMARY_NAV.map((l) => {
            const key = NAV_KEYS[l.href];
            return (
              <li>
                <a
                  href={l.href}
                  aria-current={path.startsWith(l.href) ? 'page' : undefined}
                  data-i18n={key}
                  data-en={l.label}
                >
                  {l.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="header-actions">
      <LangSwitcher />
      <ThemeToggle />
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.getAttribute('data-open') === 'true';
    nav?.setAttribute('data-open', open ? 'false' : 'true');
    toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
  });
</script>

---
import { SITE } from '../../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="footer-col">
      <span class="footer-brand__logo" aria-hidden="true">C</span>
      <strong>{SITE.name}</strong>
      <p data-i18n="footer.tagline" data-en={SITE.tagline}>{SITE.tagline}.</p>
      <p class="muted" data-i18n="footer.free" data-en="100% free. No sign-up. No tracking.">
        100% free. No sign-up. No tracking.
      </p>
    </div>
    <nav class="footer-col" aria-label="Tools">
      <h4 data-i18n="footer.colTools" data-en="Tools">Tools</h4>
      <ul>
        <li><a href="/calculators/" data-i18n="footer.toolsCalculators" data-en="Calculators">Calculators</a></li>
        <li><a href="/converters/" data-i18n="footer.toolsConverters" data-en="Converters">Converters</a></li>
        <li><a href="/generators/" data-i18n="footer.toolsGenerators" data-en="Generators">Generators</a></li>
      </ul>
    </nav>
    <nav class="footer-col" aria-label="Company">
      <h4 data-i18n="footer.colCompany" data-en="Company">Company</h4>
      <ul>
        <li><a href="/about/" data-i18n="footer.companyAbout" data-en="About">About</a></li>
        <li><a href="/contact/" data-i18n="footer.companyContact" data-en="Contact">Contact</a></li>
        <li><a href="/privacy/" data-i18n="footer.companyPrivacy" data-en="Privacy Policy">Privacy Policy</a></li>
        <li><a href="/terms/" data-i18n="footer.companyTerms" data-en="Terms of Service">Terms of Service</a></li>
      </ul>
    </nav>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} {SITE.name}. <span data-i18n="footer.rights" data-en="All rights reserved.">All rights reserved.</span></p>
    <p class="muted" data-i18n="footer.disclaimer" data-en="Calculators provide estimates only and are not financial, tax, or legal advice.">
      Calculators provide estimates only and are not financial, tax, or legal advice.
    </p>
  </div>
</footer>

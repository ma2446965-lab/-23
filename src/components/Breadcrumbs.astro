---
interface Crumb {
  name: string;
  href: string;
  /** Optional i18n key; falls back to `name` (English) when absent. */
  i18nKey?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  {
    items.map((c, i) => (
      <span class="crumb">
        {i > 0 && <span class="sep" aria-hidden="true">/</span>}
        {i < items.length - 1 ? (
          <a href={c.href} data-i18n={c.i18nKey} data-en={c.name}>{c.name}</a>
        ) : (
          <span aria-current="page" data-i18n={c.i18nKey} data-en={c.name}>{c.name}</span>
        )}
      </span>
    ))
  }
</nav>

<style>
  .breadcrumbs .crumb {
    white-space: nowrap;
  }
  .breadcrumbs .sep {
    margin: 0 0.4rem;
    color: var(--text-faint);
  }
</style>

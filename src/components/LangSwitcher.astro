---
import { LANGUAGES } from '../i18n/config';
const defaultLang = LANGUAGES[0]!; // English
---

<div class="lang-switcher">
  <button
    id="lang-button"
    class="lang-button"
    type="button"
    aria-haspopup="true"
    aria-expanded="false"
    data-i18n-attr="aria-label:lang.label"
  >
    <span class="lang-button__flag" aria-hidden="true">{defaultLang.flag}</span>
    <span class="lang-button__name">{defaultLang.native}</span>
    <span class="lang-button__caret" aria-hidden="true">▾</span>
  </button>

  <div id="lang-menu" class="lang-menu" role="menu" data-i18n-attr="aria-label:lang.select">
    <div class="lang-menu__search">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="text"
        class="lang-menu__input"
        id="lang-search"
        placeholder=""
        data-i18n-attr="placeholder:lang.search"
        aria-label="Search languages"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <div class="lang-menu__list" id="lang-list">
      {
        LANGUAGES.map((l) => (
          <button class="lang-item" type="button" role="menuitem" data-lang={l.code} data-native={l.native} data-english={l.english}>
            <span class="lang-item__flag" aria-hidden="true">{l.flag}</span>
            <span class="lang-item__native">{l.native}</span>
            <span class="lang-item__en">{l.english}</span>
          </button>
        ))
      }
      <p class="lang-empty" id="lang-empty" hidden>No languages found</p>
    </div>
  </div>
</div>

<script>
  // Live filter for the language dropdown. The open/close + selection
  // behaviour is handled by the shared i18n engine (src/i18n/index.ts);
  // here we only narrow the visible list as the visitor types.
  const menu = document.getElementById('lang-menu');
  const input = document.getElementById('lang-search') as HTMLInputElement | null;
  const empty = document.getElementById('lang-empty');
  const items = Array.from(document.querySelectorAll<HTMLElement>('#lang-list .lang-item'));

  function applyFilter() {
    const q = (input?.value || '').trim().toLowerCase();
    let visible = 0;
    for (const item of items) {
      const hay = `${item.dataset.native} ${item.dataset.english} ${item.dataset.lang}`.toLowerCase();
      const match = !q || hay.includes(q);
      item.hidden = !match;
      if (match) visible++;
    }
    if (empty) empty.hidden = visible !== 0;
  }

  input?.addEventListener('input', applyFilter);
  // Reset filter whenever the menu is (re)opened.
  const btn = document.getElementById('lang-button');
  btn?.addEventListener('click', () => {
    setTimeout(() => {
      if (menu?.classList.contains('is-open')) {
        if (input) input.value = '';
        applyFilter();
        input?.focus();
      }
    }, 0);
  });
</script>

<form id="tc-form" class="tool-form" novalidate>
  <div class="field"><label for="tc-in">Input text</label><textarea id="tc-in" class="input" spellcheck="false">The Quick Brown Fox Jumps Over The Lazy Dog</textarea></div>
  <div class="actions">
    <button type="button" class="btn btn-ghost tc-btn" data-f="toUpperCase">UPPERCASE</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toLowerCase">lowercase</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toTitleCase">Title Case</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toSentenceCase">Sentence case</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toCamelCase">camelCase</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toSnakeCase">snake_case</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toKebabCase">kebab-case</button>
    <button type="button" class="btn btn-ghost tc-btn" data-f="toAlternatingCase">aLtErNaTiNg</button>
  </div>
  <div class="field"><label for="tc-out">Output</label><textarea id="tc-out" class="input" readonly spellcheck="false"></textarea></div>
  <div class="actions"><button type="button" id="tc-copy" class="btn btn-ghost copy-btn" data-i18n="btn.copy">Copy</button></div>
</form>

<script>
  import * as tc from '../../core/text-case';
  import { $ } from '../../lib/dom';

  const out = $('tc-out') as HTMLTextAreaElement;

  function apply(fn: keyof typeof tc) {
    const text = ($('tc-in') as HTMLTextAreaElement)?.value ?? '';
    out.value = (tc[fn] as (s: string) => string)(text);
  }

  document.querySelectorAll('.tc-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = (btn as HTMLElement).getAttribute('data-f') as keyof typeof tc;
      apply(f);
    });
  });
  $('tc-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(out.value);
      const b = $('tc-copy'); if (b) b.textContent = 'Copied!';
      setTimeout(() => b && (b.textContent = 'Copy'), 1500);
    } catch {}
  });
  apply('toLowerCase');
</script>

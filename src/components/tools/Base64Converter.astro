<form id="b64-form" class="tool-form" novalidate>
  <div class="field"><label for="b64-dir">Conversion</label>
    <select id="b64-dir" class="select">
      <option value="encode" selected>Encode (text → Base64)</option>
      <option value="decode">Decode (Base64 → text)</option>
    </select>
  </div>
  <div class="field"><label for="b64-in">Input</label>
    <textarea id="b64-in" class="input" spellcheck="false">Hello, CalcUtils!</textarea>
  </div>
  <div class="field"><label for="b64-out">Output</label>
    <textarea id="b64-out" class="input" readonly spellcheck="false"></textarea>
  </div>
  <div class="actions">
    <button type="button" id="b64-convert" class="btn btn-primary">Convert</button>
    <button type="button" id="b64-copy" class="btn btn-ghost copy-btn">Copy</button>
  </div>
  <p id="b64-error" class="error-text" role="alert"></p>
</form>

<script>
  import { encodeBase64, decodeBase64 } from '../../core/base64';
  import { $ } from '../../lib/dom';

  const dirSel = $('b64-dir');
  const inEl = $('b64-in') as HTMLTextAreaElement;
  const outEl = $('b64-out') as HTMLTextAreaElement;
  const errorEl = $('b64-error');

  function convert() {
    errorEl.textContent = '';
    try {
      outEl.value = dirSel?.value === 'encode' ? encodeBase64(inEl.value) : decodeBase64(inEl.value);
    } catch (e) {
      errorEl.textContent = 'Invalid input: ' + (e instanceof Error ? e.message : String(e));
    }
  }

  $('b64-convert')?.addEventListener('click', convert);
  dirSel?.addEventListener('change', convert);
  $('b64-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(outEl.value);
      const b = $('b64-copy'); if (b) b.textContent = 'Copied!';
      setTimeout(() => b && (b.textContent = 'Copy'), 1500);
    } catch {}
  });
  convert();
</script>

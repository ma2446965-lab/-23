<form id="inv-form" class="tool-form" novalidate>
  <div class="input-row">
    <div class="field"><label for="inv-from">From</label><input id="inv-from" class="input" type="text" value="CalcUtils LLC" /></div>
    <div class="field"><label for="inv-to">Bill to</label><input id="inv-to" class="input" type="text" value="Client Name" /></div>
  </div>
  <div class="field"><label for="inv-no">Invoice #</label><input id="inv-no" class="input" type="text" value="INV-001" /></div>

  <h3 class="sub">Line items</h3>
  <div id="inv-items">
    <div class="inv-row">
      <input class="input inv-desc" placeholder="Description" value="Web design" />
      <input class="input inv-qty" type="number" min="0" value="1" />
      <input class="input inv-price" type="number" min="0" step="0.01" value="500" />
    </div>
    <div class="inv-row">
      <input class="input inv-desc" placeholder="Description" value="Hosting (1 yr)" />
      <input class="input inv-qty" type="number" min="0" value="1" />
      <input class="input inv-price" type="number" min="0" step="0.01" value="120" />
    </div>
    <div class="inv-row">
      <input class="input inv-desc" placeholder="Description" />
      <input class="input inv-qty" type="number" min="0" value="0" />
      <input class="input inv-price" type="number" min="0" step="0.01" value="0" />
    </div>
  </div>

  <div class="field"><label for="inv-tax">Tax rate (%)</label><input id="inv-tax" class="input" type="number" min="0" step="0.1" value="0" /></div>

  <div class="actions">
    <button type="button" id="inv-dl" class="btn btn-primary">Download PDF</button>
  </div>

  <div id="inv-result" class="result" aria-live="polite">
    <dl>
      <dt>Subtotal</dt><dd id="inv-sub">$0.00</dd>
      <dt>Tax</dt><dd id="inv-tax-amt">$0.00</dd>
      <dt>Total</dt><dd class="total" id="inv-total">$0.00</dd>
    </dl>
  </div>
</form>

<script>
  import { jsPDF } from 'jspdf';
  import { calcInvoice } from '../../core/invoice';
  import { formatCurrency } from '../../lib/format';
  import { $ } from '../../lib/dom';

  function readItems() {
    const rows = Array.from(document.querySelectorAll('#inv-items .inv-row'));
    return rows
      .map((r) => ({
        description: (r.querySelector('.inv-desc') as HTMLInputElement)?.value ?? '',
        qty: parseFloat((r.querySelector('.inv-qty') as HTMLInputElement)?.value ?? '0') || 0,
        price: parseFloat((r.querySelector('.inv-price') as HTMLInputElement)?.value ?? '0') || 0,
      }))
      .filter((it) => it.description.trim() !== '');
  }

  function compute() {
    const items = readItems();
    const tax = parseFloat(($('inv-tax') as HTMLInputElement)?.value ?? '0') || 0;
    const t = calcInvoice(items, tax);
    $('inv-sub').textContent = formatCurrency(t.subtotal);
    $('inv-tax-amt').textContent = formatCurrency(t.tax);
    $('inv-total').textContent = formatCurrency(t.total);
  }

  document.querySelectorAll('#inv-items input').forEach((el) => el.addEventListener('input', compute));
  $('inv-tax')?.addEventListener('input', compute);

  $('inv-dl')?.addEventListener('click', () => {
    const items = readItems();
    const tax = parseFloat(($('inv-tax') as HTMLInputElement)?.value ?? '0') || 0;
    const t = calcInvoice(items, tax);
    const doc = new jsPDF();
    let y = 20;
    doc.setFontSize(18);
    doc.text(($('inv-from') as HTMLInputElement)?.value ?? 'Invoice', 14, y);
    doc.setFontSize(11);
    y += 8;
    doc.text(`Invoice: ${($('inv-no') as HTMLInputElement)?.value ?? ''}`, 14, y);
    y += 6;
    doc.text(`Bill to: ${($('inv-to') as HTMLInputElement)?.value ?? ''}`, 14, y);
    y += 10;
    doc.setFontSize(12);
    doc.text('Description', 14, y);
    doc.text('Qty', 120, y);
    doc.text('Price', 150, y);
    doc.text('Total', 180, y);
    y += 4;
    doc.line(14, y, 196, y);
    y += 8;
    items.forEach((it) => {
      const lineTotal = it.qty * it.price;
      doc.text(it.description.slice(0, 38), 14, y);
      doc.text(String(it.qty), 120, y);
      doc.text(formatCurrency(it.price), 150, y);
      doc.text(formatCurrency(lineTotal), 180, y);
      y += 8;
    });
    y += 4;
    doc.line(14, y, 196, y);
    y += 8;
    doc.text(`Subtotal: ${formatCurrency(t.subtotal)}`, 140, y);
    y += 6;
    doc.text(`Tax: ${formatCurrency(t.tax)}`, 140, y);
    y += 6;
    doc.setFontSize(13);
    doc.text(`Total: ${formatCurrency(t.total)}`, 140, y);
    doc.save(`invoice-${($('inv-no') as HTMLInputElement)?.value ?? '001'}.pdf`);
  });

  compute();
</script>

<style>
  .sub { font-size: 1rem; margin: 0.8rem 0 0.4rem; color: var(--color-ink-700); }
  .inv-row { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem; }
</style>

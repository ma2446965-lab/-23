<form id="cal-form" class="tool-form" novalidate>
  <div class="input-row">
    <div class="field"><label for="cal-gender">Sex</label>
      <select id="cal-gender" class="select"><option value="male">Male</option><option value="female">Female</option></select>
    </div>
    <div class="field"><label for="cal-age">Age</label><input id="cal-age" class="input" type="number" inputmode="decimal" min="1" value="30" /></div>
  </div>
  <div class="field"><label for="cal-unit">Units</label>
    <select id="cal-unit" class="select"><option value="metric">Metric (kg, cm)</option><option value="imperial">Imperial (lb, in)</option></select>
  </div>
  <div class="input-row">
    <div class="field"><label for="cal-weight">Weight</label><input id="cal-weight" class="input" type="number" inputmode="decimal" min="0" step="0.1" value="70" /></div>
    <div class="field"><label for="cal-height">Height</label><input id="cal-height" class="input" type="number" inputmode="decimal" min="0" step="0.1" value="175" /></div>
  </div>
  <div class="field"><label for="cal-act">Activity level</label>
    <select id="cal-act" class="select">
      <option value="sedentary">Sedentary (little/no exercise)</option>
      <option value="light">Light (1–3 days/week)</option>
      <option value="moderate" selected>Moderate (3–5 days/week)</option>
      <option value="active">Active (6–7 days/week)</option>
      <option value="very">Very active (physical job / 2× day)</option>
    </select>
  </div>
  <div class="actions">
    <button type="submit" class="btn btn-primary">Calculate</button>
    <button type="reset" class="btn btn-ghost">Reset</button>
  </div>
  <p id="cal-error" class="error-text" role="alert"></p>
  <div id="cal-result" class="result" aria-live="polite" hidden>
    <dl>
      <dt>BMR (base calories)</dt><dd id="cal-bmr"></dd>
      <dt>Maintain weight (TDEE)</dt><dd class="total" id="cal-maintain"></dd>
      <dt>Lose weight (~0.8×)</dt><dd id="cal-lose"></dd>
      <dt>Gain weight (~1.15×)</dt><dd id="cal-gain"></dd>
    </dl>
  </div>
</form>

<script>
  import { calcCalories } from '../../core/calorie';
  import { formatNumber } from '../../lib/format';
  import { $ } from '../../lib/dom';

  const form = $('cal-form');
  const result = $('cal-result');
  const errorEl = $('cal-error');

  function compute() {
    errorEl.textContent = '';
    const weight = parseFloat($('cal-weight')?.value ?? '');
    const height = parseFloat($('cal-height')?.value ?? '');
    const age = parseFloat($('cal-age')?.value ?? '');
    if (![weight, height, age].every(Number.isFinite) || weight <= 0 || height <= 0) {
      result.hidden = true;
      errorEl.textContent = 'Enter valid positive values.';
      return;
    }
    const r = calcCalories({
      weight,
      height,
      age,
      gender: $('cal-gender')?.value === 'female' ? 'female' : 'male',
      unit: $('cal-unit')?.value === 'imperial' ? 'imperial' : 'metric',
      activity: $('cal-act')?.value ?? 'moderate',
    });
    $('cal-bmr').textContent = `${formatNumber(r.bmr, 'en-US', 0)} cal/day`;
    $('cal-maintain').textContent = `${formatNumber(r.maintain, 'en-US', 0)} cal/day`;
    $('cal-lose').textContent = `${formatNumber(r.lose, 'en-US', 0)} cal/day`;
    $('cal-gain').textContent = `${formatNumber(r.gain, 'en-US', 0)} cal/day`;
    result.hidden = false;
  }

  form?.addEventListener('input', compute);
  form?.addEventListener('submit', (e: Event) => { e.preventDefault(); compute(); });
  compute();
</script>

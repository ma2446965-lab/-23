<form id="pw-form" class="tool-form" novalidate>
  <div class="field">
    <label for="pw-length">Length: <span id="pw-len-label">16</span></label>
    <input id="pw-length" class="input" type="range" min="4" max="64" step="1" value="16" />
  </div>
  <div class="pw-options">
    <label><input type="checkbox" id="pw-upper" checked /> Uppercase (A-Z)</label>
    <label><input type="checkbox" id="pw-lower" checked /> Lowercase (a-z)</label>
    <label><input type="checkbox" id="pw-num" checked /> Numbers (0-9)</label>
    <label><input type="checkbox" id="pw-sym" checked /> Symbols (!@#$)</label>
    <label><input type="checkbox" id="pw-nosim" /> Exclude similar (i, l, 1, O, 0)</label>
  </div>

  <div class="field">
    <label for="pw-out">Generated password</label>
    <div class="input-group">
      <input id="pw-out" class="input" type="text" readonly value="" />
      <button type="button" id="pw-copy" class="btn btn-ghost copy-btn" data-i18n="btn.copy">Copy</button>
    </div>
  </div>

  <div class="strength-meter" aria-hidden="true"><span id="pw-strength-bar"></span></div>
  <p id="pw-strength-label" class="strength-label"></p>

  <div class="actions">
    <button type="button" id="pw-generate" class="btn btn-primary" data-i18n="btn.generate">Generate</button>
    <button type="reset" class="btn btn-ghost" data-i18n="btn.reset">Reset</button>
  </div>
</form>

<script>
  import { generatePassword } from '../../core/password';
  import { $ } from '../../lib/dom';

  function rng(): number {
    const cryptoObj = window.crypto || (window as any).msCrypto;
    const arr = new Uint32Array(1);
    cryptoObj.getRandomValues(arr);
    return (arr[0] ?? 0) / 4294967296;
  }

  const lenInput = $('pw-length') as HTMLInputElement;
  const lenLabel = $('pw-len-label');
  const out = $('pw-out') as HTMLInputElement;
  const bar = $('pw-strength-bar');
  const strengthLabel = $('pw-strength-label');

  const COLORS: Record<string, string> = {
    Weak: '#dc2626',
    Fair: '#d97706',
    Strong: '#4f46e5',
    'Very Strong': '#16a34a',
  };
  const WIDTHS: Record<string, string> = {
    Weak: '25%',
    Fair: '50%',
    Strong: '75%',
    'Very Strong': '100%',
  };

  function generate() {
    const length = parseInt(lenInput?.value ?? '16', 10);
    const res = generatePassword(
      {
        length,
        uppercase: ($('pw-upper') as HTMLInputElement)?.checked,
        lowercase: ($('pw-lower') as HTMLInputElement)?.checked,
        numbers: ($('pw-num') as HTMLInputElement)?.checked,
        symbols: ($('pw-sym') as HTMLInputElement)?.checked,
        excludeSimilar: ($('pw-nosim') as HTMLInputElement)?.checked,
      },
      rng,
    );
    if (out) out.value = res.password;
    if (bar) {
      bar.style.width = WIDTHS[res.strength] ?? '50%';
      bar.style.background = COLORS[res.strength] ?? '#d97706';
    }
    if (strengthLabel) {
      strengthLabel.textContent = `${res.strength} · ${res.entropyBits} bits of entropy`;
      strengthLabel.style.color = COLORS[res.strength] ?? '#d97706';
    }
  }

  lenInput?.addEventListener('input', () => {
    if (lenLabel) lenLabel.textContent = lenInput.value;
    generate();
  });
  ['pw-upper', 'pw-lower', 'pw-num', 'pw-sym', 'pw-nosim'].forEach((id) => {
    $(id)?.addEventListener('change', generate);
  });
  $('pw-generate')?.addEventListener('click', generate);
  $('pw-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(out.value);
      const btn = $('pw-copy');
      if (btn) btn.textContent = 'Copied!';
      setTimeout(() => btn && (btn.textContent = 'Copy'), 1500);
    } catch {
      /* clipboard unavailable */
    }
  });
  generate();
</script>

<style>
  .pw-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.4rem 1rem;
    margin: 0.5rem 0;
  }
  .pw-options label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-ink-700);
  }
</style>

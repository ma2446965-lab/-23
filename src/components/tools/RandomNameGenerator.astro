<form id="rn-form" class="tool-form" novalidate>
  <div class="field"><label for="rn-count">How many names?</label><input id="rn-count" class="input" type="number" min="1" max="100" value="10" /></div>
  <div class="actions">
    <button type="button" id="rn-gen" class="btn btn-primary">Generate</button>
    <button type="button" id="rn-copy" class="btn btn-ghost copy-btn">Copy</button>
  </div>
  <div class="field"><label for="rn-out">Output</label><textarea id="rn-out" class="input" readonly spellcheck="false"></textarea></div>
</form>

<script>
  import { randomNames } from '../../core/random-name';
  import { $ } from '../../lib/dom';

  const out = $('rn-out') as HTMLTextAreaElement;

  function gen() {
    const n = Math.max(1, Math.min(100, parseInt(($('rn-count') as HTMLInputElement)?.value ?? '10', 10) || 10));
    out.value = randomNames(n).join('\n');
  }

  $('rn-gen')?.addEventListener('click', gen);
  $('rn-count')?.addEventListener('input', gen);
  $('rn-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(out.value);
      const b = $('rn-copy'); if (b) b.textContent = 'Copied!';
      setTimeout(() => b && (b.textContent = 'Copy'), 1500);
    } catch {}
  });
  gen();
</script>

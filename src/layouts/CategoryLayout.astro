---
import { SITE } from '../consts';
import type { CategoryMeta, ToolMeta } from '../data/types';
import { breadcrumbJsonLd } from '../lib/seo';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  category: CategoryMeta;
  tools: ToolMeta[];
}
const { category, tools } = Astro.props;
const slug = category.slug;

const crumbs = [
  { name: 'Home', href: '/', i18nKey: 'breadcrumb.home' },
  { name: category.title, href: `/${category.slug}/`, i18nKey: `cat.${slug}` },
];

const jsonLd = [breadcrumbJsonLd(crumbs.map((c) => ({ name: c.name, url: `${SITE.url}${c.href}` })))];
---

<BaseLayout
  title={`${category.title} — Free Online Tools`}
  description={category.description}
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={crumbs} />

    <header class="category-header">
      <h1 data-i18n={`cat.${slug}`} data-en={category.title}>{category.title}</h1>
      <p class="lead" data-i18n={`cat.${slug}.desc`} data-en={category.description}>{category.description}</p>
    </header>

    <section class="grid-tools">
      {tools.map((t) => (
        <a class="card tool-card" href={`/${t.category}/${t.slug}/`}>
          <span class="tool-card__icon" aria-hidden="true">{t.icon}</span>
          <span class="badge" data-i18n={`cat.${t.category}`} data-en={t.category}>{t.category}</span>
          <h3 data-i18n={`tool.${t.slug}.title`} data-en={t.title}>{t.title}</h3>
          <p data-i18n={`tool.${t.slug}.description`} data-en={t.description}>{t.description}</p>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .category-header {
    margin: 1rem 0 1.5rem;
  }
  .category-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0.4rem 0 0.5rem;
  }
  .lead {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin: 0;
    max-width: 70ch;
  }
</style>

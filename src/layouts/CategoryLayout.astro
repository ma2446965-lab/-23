---
import { SITE } from '../consts';
import type { CategoryMeta, ToolMeta } from '../data/types';
import { breadcrumbJsonLd } from '../lib/seo';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  category: CategoryMeta;
  tools: ToolMeta[];
}
const { category, tools } = Astro.props;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: category.title, href: `/${category.slug}/` },
];

const jsonLd = [
  breadcrumbJsonLd(crumbs.map((c) => ({ name: c.name, url: `${SITE.url}${c.href}` }))),
];
---

<BaseLayout
  title={`${category.title} — Free Online Tools`}
  description={category.description}
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={crumbs} />

    <header class="category-header">
      <h1>{category.title}</h1>
      <p class="lead">{category.description}</p>
    </header>

    <section class="grid-tools">
      {
        tools.map((t) => (
          <a class="card tool-card" href={`/${t.category}/${t.slug}/`}>
            <span class="badge">{t.category}</span>
            <h3>{t.title}</h3>
            <p>{t.description}</p>
          </a>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style>
  .category-header {
    margin: 1rem 0 1.5rem;
  }
  .category-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0.4rem 0 0.5rem;
  }
  .lead {
    font-size: 1.05rem;
    color: var(--color-ink-600);
    margin: 0;
    max-width: 70ch;
  }
</style>

---
import { SITE } from '../consts';
import type { ToolMeta } from '../data/types';
import { categories, getTool } from '../data/tools';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedTools from '../components/RelatedTools.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import { softwareAppJsonLd, faqJsonLd, breadcrumbJsonLd } from '../lib/seo';

interface Props {
  tool: ToolMeta;
}
const { tool } = Astro.props;

const cat = categories.find((c) => c.slug === tool.category)!;
const related = tool.related.map(getTool).filter(Boolean) as ToolMeta[];
const slug = tool.slug;

const crumbs = [
  { name: 'Home', href: '/', i18nKey: 'breadcrumb.home' },
  { name: cat.title, href: `/${cat.slug}/`, i18nKey: `cat.${cat.slug}` },
  { name: tool.title, href: `/${cat.slug}/${tool.slug}/`, i18nKey: `tool.${slug}.title` },
];

const jsonLd = [
  softwareAppJsonLd(tool),
  faqJsonLd(tool.faq),
  breadcrumbJsonLd(crumbs.map((c) => ({ name: c.name, url: `${SITE.url}${c.href}` }))),
];
---

<BaseLayout title={tool.title} description={tool.description} ogType="article" jsonLd={jsonLd}>
  <div class="container tool-page">
    <Breadcrumbs items={crumbs} />

    <header class="tool-header">
      <h1 data-i18n={`tool.${slug}.title`} data-en={tool.title}>{tool.title}</h1>
      <p class="lead" data-i18n={`tool.${slug}.description`} data-en={tool.description}>{tool.description}</p>
    </header>

    <AdSlot id="top" label="Advertisement" />

    <section class="tool-interactive card" aria-label={tool.title}>
      <slot />
    </section>

    <AdSlot id="inContent" label="Advertisement" />

    <section class="prose tool-content">
      <h2 data-i18n="tool.about" data-en="About this tool">About this tool</h2>
      <p data-i18n={`tool.${slug}.intro`} data-en={tool.content.intro}>{tool.content.intro}</p>

      <h2 data-i18n="tool.howTo" data-en="How to use">How to use</h2>
      <ol>
        {tool.content.howTo.map((step, i) => <li data-i18n={`tool.${slug}.howTo.${i}`} data-en={step}>{step}</li>)}
      </ol>

      {
        tool.content.example && (
          <>
            <h2 data-i18n="tool.example" data-en="Example">Example</h2>
            <p data-i18n={`tool.${slug}.example`} data-en={tool.content.example}>{tool.content.example}</p>
          </>
        )
      }

      {
        tool.content.assumptions && tool.content.assumptions.length > 0 && (
          <>
            <h2 data-i18n="tool.assumptions" data-en="Assumptions & limitations">Assumptions &amp; limitations</h2>
            <ul>
              {tool.content.assumptions.map((a, i) => (
                <li data-i18n={`tool.${slug}.assumptions.${i}`} data-en={a}>{a}</li>
              ))}
            </ul>
          </>
        )
      }
    </section>

    <AdSlot id="related" label="Advertisement" />

    {
      related.length > 0 && (
        <section class="related">
          <h2 data-i18n="tool.related" data-en="Related tools">Related tools</h2>
          <RelatedTools tools={related} />
        </section>
      )
    }

    <section class="prose faq">
      <h2 data-i18n="tool.faq" data-en="Frequently asked questions">Frequently asked questions</h2>
      {
        tool.faq.map((f, i) => (
          <div class="faq-item">
            <h3 data-i18n={`tool.${slug}.faq.${i}.q`} data-en={f.q}>{f.q}</h3>
            <p data-i18n={`tool.${slug}.faq.${i}.a`} data-en={f.a}>{f.a}</p>
          </div>
        ))
      }
    </section>
  </div>
</BaseLayout>

# Copy this file to .env and fill in real values.
# These are PUBLIC client-side variables (safe to expose to the browser).

# Absolute production URL (no trailing slash). Required for canonical, sitemap & JSON-LD.
PUBLIC_SITE_URL=https://www.calcutils.com

# Google AdSense publisher ID, e.g. ca-pub-1234567890123456
# Leave empty to show reserved placeholder ad slots (no external requests).
PUBLIC_ADSENSE_CLIENT=
